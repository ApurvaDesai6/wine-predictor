# Wine Predictor Environment Variables

# OpenAI API key (for wine label VLM scanning)
OPENAI_API_KEY=sk-your-key-here

# Google Custom Search (for wine price search)
# Create at: https://programmablesearchengine.google.com/
# Get API key at: https://console.cloud.google.com/apis/credentials
GOOGLE_SEARCH_API_KEY=your-google-api-key
GOOGLE_SEARCH_CX=your-search-engine-id

# Database (Prisma - SQLite for local dev)
DATABASE_URL=file:./dev.db
