# Wine Predictor Environment Variables

# Z.AI API Key (free - get one at https://z.ai/manage-apikey/apikey-list)
# Required for wine label scanning (VLM). Wine search works without it.
# Uses GLM-4.6V-Flash (free tier, no cost)
ZAI_API_KEY=your-key-here

# Database (Prisma - SQLite for local dev)
DATABASE_URL=file:./dev.db
